    "@vitejs/plugin-vue": "^5.2.4",
    "axios": "^1.15.1",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.7",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.9.0",
